* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html,
body {
  width: 100%;
  height: 100%;
  background: #000;
  color: #fff;
  font-family: Arial, Helvetica, sans-serif;
  overflow: hidden;
}

.portfolio {
  width: 100vw;
  height: 100vh;
  position: relative;
  padding: 24px 36px;
  overflow: hidden;
}

.header {
  position: relative;
  z-index: 10;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 13px;
  font-weight: 700;
}

.logo {
  letter-spacing: -0.3px;
}

.nav {
  display: flex;
  gap: 36px;
  margin-right: 260px;
}

.nav a,
.bottom-menu a {
  color: #fff;
  text-decoration: none;
}

.title {
  position: absolute;
  top: 95px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 120px;
  line-height: 0.9;
  font-weight: 800;
  letter-spacing: -5px;
  z-index: 1;
  white-space: nowrap;
  pointer-events: none;
}

.work-scroll {
  position: absolute;
  top: 190px;
  left: 0;
  width: 100vw;
  height: 520px;
  display: flex;
  gap: 160px;
  overflow-x: auto;
  overflow-y: hidden;
  padding: 0 170px;
  scroll-snap-type: x proximity;
  cursor: grab;
  z-index: 5;
}

.work-scroll::-webkit-scrollbar {
  display: none;
}

.work-card {
  flex: 0 0 360px;
  scroll-snap-align: center;
}

.work-card img {
  width: 360px;
  height: 205px;
  object-fit: cover;
  display: block;
  background: #222;
}

.work-card p {
  margin-top: 8px;
  font-size: 13px;
  font-weight: 700;
}

.card-1 {
  margin-top: 10px;
}

.card-2 {
  margin-top: 160px;
}

.card-3 {
  margin-top: 70px;
}

.card-4 {
  margin-top: 125px;
}

.card-5 {
  margin-top: 30px;
}

.bottom-menu {
  position: fixed;
  left: 36px;
  bottom: 28px;
  z-index: 20;
  display: flex;
  gap: 28px;
  font-size: 13px;
  font-weight: 700;
}

@media (max-width: 768px) {
  .portfolio {
    padding: 20px;
  }

  .nav {
    margin-right: 0;
    gap: 16px;
  }

  .title {
    top: 90px;
    font-size: 64px;
    letter-spacing: -2px;
  }

  .work-scroll {
    top: 180px;
    gap: 60px;
    padding: 0 40px;
  }

  .work-card {
    flex-basis: 280px;
  }

  .work-card img {
    width: 280px;
    height: 170px;
  }

  .bottom-menu {
    left: 20px;
    gap: 16px;
    font-size: 11px;
  }
}
